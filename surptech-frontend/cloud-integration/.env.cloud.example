# Cloud Integration Environment Variables
# Copy this file to .env.local and fill in your actual values

# ============================================
# FIREBASE CONFIGURATION
# ============================================
# Get these values from Firebase Console: https://console.firebase.google.com
# Project Settings > General > Your apps > SDK setup and configuration

NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================
# GOOGLE CLOUD PLATFORM CONFIGURATION
# ============================================
# Get these values from GCP Console: https://console.cloud.google.com

# GCP Project ID
GCP_PROJECT_ID=your-gcp-project-id

# Path to service account credentials JSON file
# Download from: IAM & Admin > Service Accounts > Create Key
GCP_CREDENTIALS_PATH=./gcp-credentials.json

# GCP Storage Bucket Name
GCP_BUCKET_NAME=your-bucket-name

# GCP Region (optional, defaults to us-central1)
GCP_REGION=us-central1

# ============================================
# MONGODB CONFIGURATION
# ============================================
# Get connection string from MongoDB Atlas: https://cloud.mongodb.com

# MongoDB Connection URI
# Format: mongodb+srv://username:password@cluster.mongodb.net/
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority

# MongoDB Database Name
MONGODB_DB_NAME=surptech

# MongoDB Connection Pool Settings (optional)
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=2
MONGODB_MAX_IDLE_TIME_MS=60000
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
MONGODB_SOCKET_TIMEOUT_MS=45000

# ============================================
# EXISTING BACKEND API CONFIGURATION
# ============================================
# These are your existing backend service URLs

# Data Aggregator Service
NEXT_PUBLIC_DATA_AGGREGATOR_URL=http://localhost:5555

# Customer Profile Service
NEXT_PUBLIC_CUSTOMER_PROFILE_URL=http://localhost:8081

# Credit Profile Service
NEXT_PUBLIC_CREDIT_PROFILE_URL=http://localhost:8082

# ============================================
# OPTIONAL: FEATURE FLAGS
# ============================================
# Enable/disable cloud features

# Enable Firebase features
NEXT_PUBLIC_ENABLE_FIREBASE=true

# Enable GCP features
NEXT_PUBLIC_ENABLE_GCP=true

# Enable MongoDB caching
NEXT_PUBLIC_ENABLE_MONGODB_CACHE=true

# Cache expiration time in minutes
MONGODB_CACHE_EXPIRATION_MINUTES=60

# ============================================
# OPTIONAL: SECURITY SETTINGS
# ============================================

# API Rate Limiting (requests per minute)
API_RATE_LIMIT=100

# Maximum file upload size (in bytes)
MAX_FILE_UPLOAD_SIZE=10485760

# Allowed file upload types (comma-separated)
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# ============================================
# DEVELOPMENT SETTINGS
# ============================================

# Node Environment
NODE_ENV=development

# Enable debug logging
DEBUG=false

# ============================================
# NOTES
# ============================================
# 
# 1. NEVER commit .env.local to version control
# 2. Add .env.local to .gitignore
# 3. Keep credentials secure and rotate regularly
# 4. Use different credentials for dev/staging/production
# 5. For production, use environment variables from your hosting platform
# 
# ============================================
